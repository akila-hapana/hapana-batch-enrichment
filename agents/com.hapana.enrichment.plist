<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hapana Local Enrichment Agent — LaunchAgent
  Starts automatically every time you log in to your Mac.

  Install (one-time):
    cp agents/com.hapana.enrichment.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.hapana.enrichment.plist

  Check status:
    launchctl list | grep hapana

  View logs:
    tail -f /tmp/hapana-agent.log

  Stop temporarily:
    launchctl unload ~/Library/LaunchAgents/com.hapana.enrichment.plist

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.hapana.enrichment.plist
    rm ~/Library/LaunchAgents/com.hapana.enrichment.plist
-->
<plist version="1.0">
<dict>

    <key>Label</key>
    <string>com.hapana.enrichment-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/akilalohanmarketing/Documents/Batch Data Enrichment App/venv/bin/python</string>
        <string>/Users/akilalohanmarketing/Documents/Batch Data Enrichment App/local_agent.py</string>
    </array>

    <!-- Reads credentials from the .env file at startup — nothing hardcoded here -->
    <key>WorkingDirectory</key>
    <string>/Users/akilalohanmarketing/Documents/Batch Data Enrichment App</string>

    <!-- Auto-start on login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart if it crashes -->
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 30s before restarting after a crash (prevents tight loop) -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/tmp/hapana-agent.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/hapana-agent-error.log</string>

</dict>
</plist>
